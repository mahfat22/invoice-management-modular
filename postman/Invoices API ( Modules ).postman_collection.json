              "raw": "{\n  \"customer_id\": 1,\n  \"invoice_date\": \"2026-06-23\",\n  \"notes\": \"Example invoice from Postman\",\n  \"items\": [\n    {\n      \"item_name\": \"Consulting\",\n      \"quantity\": 2,\n      \"unit_price\": 150,\n      \"discount_amount\": 0,\n      \"tax_amount\": 0\n    }\n  ]\n}\n"
